<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alphalete.b2b-metrics</string>

    <!-- Path is the laptop placeholder; on the machine, install_agent.py rewrites
         it to that repo path (python -m automations.day_orchestrator.install_agent
         b2b-metrics). INSTALL ON LUCY 2 ONLY — Carlos's login is what makes the
         Activation view come down sorted. -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/megan/1st Claude Folder/deploy/b2b_metrics.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/megan/1st Claude Folder</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/Users/megan/1st Claude Folder</string>
    </dict>

    <!-- DAILY incl. weekends (no Weekday key). First pass 5:30 CST, then q8m
         retries through 5:54 — SHORT ON PURPOSE: this must be FINISHED by 6:00
