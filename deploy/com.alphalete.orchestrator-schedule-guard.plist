<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alphalete.orchestrator-schedule-guard</string>

    <!-- The committed laptop path; install_agent rewrites it to THIS machine's
         repo path on bootstrap (same as every other agent here). -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/megan/1st Claude Folder/deploy/orchestrator_schedule_guard.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/megan/1st Claude Folder</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/Users/megan/1st Claude Folder</string>
    </dict>

    <!-- 2:45am every day, in the machine's LOCAL time (mini is CST) — BEFORE the
         earliest daily job (appstream-morning at 3:00am), so launchd re-loads
         EVERY timed job's schedule fresh from its plist before any of them fire.
         This is the self-heal for launchd schedule drift across all timed reports. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>45</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/megan/1st Claude Folder/output/logs/orchestrator-schedule-guard.launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/megan/1st Claude Folder/output/logs/orchestrator-schedule-guard.launchd.err.log</string>
</dict>
</plist>
