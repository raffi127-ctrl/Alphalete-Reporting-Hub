<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alphalete.session-holder</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/megan/1st Claude Folder/.venv/bin/python</string>
        <string>-u</string>
        <string>-m</string>
        <string>automations.shared.session_holder</string>
        <string>--interval</string>
        <string>6</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/megan/1st Claude Folder</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/Users/megan/1st Claude Folder</string>
    </dict>

    <!-- Start at login and keep it alive (restart if it ever exits/crashes). -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <!-- Don't hot-loop if it dies fast (e.g. unseeded): wait 30s between restarts. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/megan/1st Claude Folder/output/logs/session_holder.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/megan/1st Claude Folder/output/logs/session_holder.err.log</string>
</dict>
</plist>
