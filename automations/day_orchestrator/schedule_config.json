{
  "_meta": {
    "purpose": "Single editable source of truth for the day orchestrator. Cadence, priority, and freshness are deliberately KNOBS — tuned by hand during the ~1-week parallel dry-run (Megan 2026-06-23).",
    "weekday_convention": "Python weekday(): Mon=0, Tue=1, Wed=2, Thu=3, Fri=4, Sat=5, Sun=6 (matches dashboard.py).",
    "times": "All times are CST (the mini is Central). HH:MM 24h.",
    "priority_tiers": "P1 critical (guaranteed done daily, runs first) > P2 standard daily > P3 best-effort (runs last).",
    "freshness_target": "A DEADLINE distinct from cadence. e.g. 'monday_am' = must be current by Monday morning even if deprioritized midweek; the orchestrator escalates effective priority as the deadline nears.",
    "source_type": "tableau = readiness gate + circle-back applies | appstream = immediately ready (no probe) | api = ready | upload = MANUAL, never auto-run, only noted.",
    "probe_not_configured": "A tableau source with probe.type 'not_configured' resolves READY in --dry-run (so the full loop exercises) and NOT-READY in live (forces wiring the real view URL before cutover)."
  },

  "settings": {
    "start_time": "04:00",
    "interval_minutes": 25,
    "checkpoint_time": "07:30",
    "backstop_time": "12:00",
    "channel": "email",
    "recipients": ["Meganhidalgo1191@gmail.com", "Alphaletereporting@gmail.com"],
    "session_stale_after_minutes": 20
  },

  "sources": {
    "tableau:order_log": {
      "label": "60-day Order Log",
      "probe": {"type": "not_configured", "_todo": "wire view_url + crosstab_sheet + date_col + min_rows before live cutover"}
    },
    "tableau:churn": {
      "label": "CHURN / RafExpanded",
      "probe": {"type": "not_configured", "_todo": "wire before cutover"}
    },
    "tableau:product_sales": {
      "label": "OPT Product Sales Summary",
      "probe": {"type": "not_configured", "_todo": "wire before cutover"}
    },
    "tableau:fiber_pss": {
      "label": "Fiber Lead Performance / PSS",
      "probe": {"type": "not_configured", "_todo": "wire before cutover"}
    },
    "tableau:dispo": {
      "label": "Disposition / Time Tracker (ownerville)",
      "probe": {"type": "not_configured", "_todo": "wire before cutover"}
    }
  },

  "reports": {
    "daily_metrics": {
      "on_scheduler": true,
      "display_name": "9 Daily Metrics Report",
      "source_type": "tableau",
      "data_sources": ["tableau:order_log"],
      "_sources_note": "Internally orchestrates total_knocks, canceled_orders, ongoing_cancel, disconnects, churn, scheduled_6, order_log; sub-steps self-gate, so the unit is gated on the dominant order_log source.",
      "command": ["automations.daily_metrics.run"],
      "base_args": [],
      "cadence": {"weekdays": [0, 1, 2, 3, 4, 5, 6], "not_before": "07:00"},
      "priority": "P1",
      "freshness_target": null,
      "depends_on": [],
      "verify": {"type": "manifest", "report_id": "daily_metrics"}
    },

    "captainship_churn": {
      "on_scheduler": true,
      "display_name": "Captainship - New Internet & Wireless Churn",
