{
  "_meta": {
    "purpose": "Single editable source of truth for the day orchestrator. Cadence, priority, and freshness are deliberately KNOBS — tuned by hand during the ~1-week parallel dry-run (Megan 2026-06-23).",
    "scope": "ALL non-upload reports run on the scheduler (Megan 2026-06-23). Upload-gated reports (Financial, First/Last Sale, Frontier) stay MANUAL — see 'excluded'.",
    "weekday_convention": "Python weekday(): Mon=0, Tue=1, Wed=2, Thu=3, Fri=4, Sat=5, Sun=6 (matches dashboard.py).",
    "times": "All times are CST (the mini is Central). HH:MM 24h.",
    "priority_tiers": "P1 critical (guaranteed done daily, runs first) > P2 standard > P3 best-effort (runs last).",
    "freshness_target": "A DEADLINE distinct from cadence. e.g. 'monday_am' = must be current by Monday morning even if deprioritized midweek; the orchestrator escalates effective priority as the deadline nears.",
    "source_type": "tableau = readiness gate + circle-back applies | appstream = immediately ready (no probe) | api = ready | upload = MANUAL, never auto-run.",
    "probe_not_configured": "A tableau source with probe.type 'not_configured' resolves READY in --dry-run (so the full loop exercises) and NOT-READY in live (forces wiring the real view URL before cutover).",
    "cutover_retire_jobs": "These now run from the orchestrator — RETIRE their standalone LaunchAgents at cutover so reports don't double-run/double-post: com.alphalete.appstream-morning (daily_focus + Mon recruiter retention), com.alphalete.weather-6am, com.alphalete.brand-audit-noon, com.alphalete.recruiting-report (weekly ATT). Until cutover (dry-run week) they coexist safely — the orchestrator writes nothing."
  },

  "settings": {
    "start_time": "04:00",
    "interval_minutes": 25,
    "checkpoint_time": "07:30",
    "backstop_time": "12:00",
    "channel": "email",
    "recipients": ["Meganhidalgo1191@gmail.com", "Alphaletereporting@gmail.com"],
    "session_stale_after_minutes": 20,
    "gate_unprobed_sources": false
  },

  "sources": {
    "tableau:order_log": {"label": "60-day Order Log", "probe": {"type": "not_configured", "_todo": "wire view_url + crosstab_sheet + date_col + min_rows before live cutover"}},
    "tableau:churn": {"label": "CHURN / RafExpanded", "probe": {"type": "not_configured", "_todo": "wire before cutover"}},
    "tableau:product_sales": {"label": "OPT Product Sales Summary", "probe": {"type": "not_configured", "_todo": "wire before cutover"}},
    "tableau:fiber_pss": {"label": "Fiber Lead Performance / PSS", "probe": {"type": "not_configured", "_todo": "wire before cutover"}},
    "tableau:dispo": {"label": "Disposition / Time Tracker (ownerville)", "probe": {"type": "not_configured", "_todo": "wire before cutover"}},
    "tableau:sara_byday": {"label": "SARA by-day (org sales board)", "probe": {"type": "not_configured", "_todo": "wire before cutover"}}
  },

