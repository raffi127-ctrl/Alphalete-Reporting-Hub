.DS_Store
# Browser profiles — all variants (.browser_profile, _holder, _zoho, …) hold
# live session cookies (auth). Sensitive; never commit.
.browser_profile*
.appstream_profile/
.appstream_profile_alt/
# AppStream storage_state export — contains live SESSION cookies (auth). Sensitive;
# never commit. Exported by output/_scratch_appstream_export_state.py.
.appstream_storage_state.json
automations/shared/.appstream_storage_state.json
# ownerville storage_state export — contains live SESSION cookies (auth). Sensitive;
# never commit. Exported by output/_scratch_ownerville_export_state.py.
.ownerville_storage_state.json
automations/shared/.ownerville_storage_state.json
*.app/
# Build artifacts + Claude Code local state
build/
.claude/
Install-Recruiting-Report.command.zip
# Per-run debug screenshots from uploaded automations - regenerated on
# every run; never useful to commit. Keep the directory itself tracked
# so the script can write into it on a fresh clone.
automations/uploaded/screenshots/*.png
# Shared-library scripts are materialized from the Google Sheet on each Hub —
# they're a local cache, not source. Never commit (would also block git pull).
automations/uploaded/_shared/
# Marks a DEV machine (Megan/Claude). When present, the launcher protects
# local edits (fast-forward-updates only when the tree is clean). When ABSENT
# (teammate machines), the launcher hard-aligns to origin/main every launch so
# a stray change or wrong branch can't strand them on stale code. Machine-
# specific — never commit (committing it would disable force-align for everyone).
.dev-machine
# Frontier OPT PDFs are uploaded daily sales data (customer info) — never
# commit. The script reads them from this directory at run time; cleanup
# is per-user.
automations/uploaded/frontier/
# Scratch probe scripts (_probe_*.py) under report modules are throwaway
# debugging from one-off mapping work — never commit. Keep them around
# locally if useful, but don't track them.
automations/*/_probe_*.py
# AppStream office list — machine-regenerated on every daily_focus run
# (refresh_offices_from_page scrapes the logged-in account's offices). It's a
# per-account runtime cache, not source. Tracking it dirtied the mini's tree
# after every run and blocked `lucy update` (git pull --ff-only). Readers
# (fill._load_office_index, dashboard._all_appstream_offices) fall back to an
# empty list if it's missing, so a fresh clone just rebuilds it on first run.
automations/recruiting_report/all-offices.json

# Per-machine runner identity for mini_control (Lucy 1 / Lucy 2). Never commit.
.machine-profile

# Streamlit secrets (never commit — contains access codes, SMTP + service-account creds)
.streamlit/secrets.toml

# swag_welcome: keep the raw personal handwriting sample + build debug art off the public repo
# (the derived glyph library IS committed, so the tool still works)
resources/swag/handwriting-raw.png
resources/swag/glyphs/_debug/
